                                    #Polymorphism
class Animal:
    def speak(self):
        pass

class Cat(Animal):
    def speak(self): # Fill method name
        return "Meow"

class Dog(Animal):
    def speak(self):
        return "bhau bhau" # Fill what a dog says

animals = [Cat(), Dog()]
for animal in animals:
    print(animal.speak())




